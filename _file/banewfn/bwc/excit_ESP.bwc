wfn=*.fchk
state=1
[excit]
%process
no state ${state}
end

[grid]
%process
    electron
    esp
%command
#!/bin/bash
    mkdir -p ESP
    mv density.cub ESP/${input}_den.cub
    mv totesp.cub ESP/${input}_esp.cub
    mv ${output} ESP
    cat << EOF > ESP/esp.bat
    vmd -e esp.vmd
EOF

    cat << EOF2 > ESP/esp.vmd
    vcube *_den.cub map *_esp.cub
    set colorlow -20
    set colorhigh 20
    mol scaleminmax 0 1 -20 20
    puts "unit: kcal/mol"
EOF2
end

wfn_rebase=NO_000${state}.mwfn
[grid]
%process
    electron
    esp
%command
#!/bin/bash
    mkdir -p ESP_${state}
    mv density.cub ESP_${state}/${input}_den.cub
    mv totesp.cub ESP_${state}/${input}_esp.cub
    mv NO_000${state}.mwfn ${output} ESP_${state}
    cat << EOF > ESP_${state}/esp.bat
    vmd -e esp.vmd
EOF

    cat << EOF2 > ESP_${state}/esp.vmd
    vcube *_den.cub map *_esp.cub
    set colorlow -20
    set colorhigh 20
    mol scaleminmax 0 1 -20 20
    puts "unit: kcal/mol"
EOF2
end

