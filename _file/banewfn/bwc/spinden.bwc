[grid]
%process
    spin
%command
#!/bin/bash
mv spindensity.cub ${input}_spinden.cub

cat << EOF > spinden.bat
vmd -e spinden.vmd
EOF

cat << EOF2 > spinden.vmd
vcube ${input}_spinden.cub
end


