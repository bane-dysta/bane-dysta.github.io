wfn=*.fchk
state=(1 2)
[excit]
%process
    nto state ${state}
%command
#!/bin/bash
mv ex_${state}.fchk ${input}_NTO${state}.fch
mkdir -p NTOs
mv excit_${input}.out NTOs
end

wfn_rebase=${input}_NTO${state}.fch
[fmo]
%process
    orb index h
    orb index l
%command
#!/bin/bash
mkdir -p NTOs
mv ${input}_NTO${state}.fch fmo_${input}_NTO${state}.out NTOs
mv h.cub NTOs/${input}_NTO${state}_oH.cub
mv l.cub NTOs/${input}_NTO${state}_oL.cub
end

