wfn=*.fchk
state=(1 2 3 4 5)

[excit]
%process
    ifctdata state ${state}
    ifct state ${state} fragdef fragdef.txt
%command
#!/bin/bash
mkdir -p ${input}_IFCT
mv dislin.png ${input}_IFCT/state${state}.png
mv atmCTmat.txt ${input}_IFCT/atmCTmat${state}.txt
mv tmat.txt ${input}_IFCT/tmat${state}.txt
sed -n '/Contribution of each fragment to hole and electron/,/Intrinsic local excitation percentage/p' excit_${input}.out > ${input}_IFCT/ifctdata${state}.txt
mv ${output} ${input}_IFCT
end

