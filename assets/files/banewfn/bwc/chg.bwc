wfn=*.fchk
[charge]
%process
hirshfeld
%command
#!/bin/bash
mkdir -p ${input}_chg
mv ${input}.chg ${input}_chg/${input}_hirshfeld.chg
mv ${output} ${input}_chg
end

[charge]
%process
adch
%command
#!/bin/bash
mkdir -p ${input}_chg
mv ${input}.chg ${input}_chg/${input}_adch.chg
mv ${output} ${input}_chg
end


