wfn=*.fchk
state=?

[excit]
%process
no state ${state}
end

wfn_rebase=${input}.fchk
[no]
%process
SCF
%command
#!/bin/bash
mv new.mwfn SCF.mwfn
end

wfn_rebase=NO_000${state}.mwfn
[grid]
%process
wfn2 operator -,SCF.mwfn
electron
%command
#!/bin/bash
mv density.cub dendiff_${state}.cub
end

%command
#!/bin/bash
mkdir -p ${input}_dendiff_CI
mv dendiff_${state}.cub SCF.mwfn ${input}_dendiff_CI
end


