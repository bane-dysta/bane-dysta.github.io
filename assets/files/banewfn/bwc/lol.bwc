wfn=*.fchk
plane=?

[grid]
%process
    lol
%command
#!/bin/bash
mkdir -p ${input}_LOL
mv LOL.cub ${input}_LOL/${input}_lol.cub
cat << EOF > ${input}_LOL/lol.bat
vmd -e lol.vmd
EOF
cat << EOF2 > ${input}_LOL/lol.vmd
vcube ${input}_lol.cub
EOF2
mv ${output} ${input}_LOL
end

wfn_rebase=${input}_LOL/${input}_lol.cub
[plane_fromcub]
%process
    autoplot plane ${plane}
%command
#!/bin/bash
mv dislin.png plane.txt ${output} ${input}_LOL
end


