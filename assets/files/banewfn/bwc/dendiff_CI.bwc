wfn=*.fchk

[no]
%process
SCF
%command
#!/bin/bash
mv new.mwfn SCF.mwfn
end

wfn_rebase=${input}.fchk
[no]
%process
CI
%command
#!/bin/bash
mv new.mwfn CI.mwfn
end

wfn_rebase=CI.mwfn
[grid]
%process
wfn2 operator -,SCF.mwfn
electron
%command
#!/bin/bash
mv density.cub dendiff.cub
end

%command
#!/bin/bash
mkdir -p ${input}_dendiff_CI
mv dendiff.cub CI.mwfn SCF.mwfn ${input}_dendiff_CI
end


